  <FixedRecord type="Angular Velocity Vector" length="12">
    <NumericField name="Rate about x-axis" type="float32" units="radians/sec"/>
    <NumericField name="Rate about y-axis" type="float32" units="radians/sec"/>
    <NumericField name="Rate about z-axis" type="float32" units="radians/sec"/>
  </FixedRecord>

  <FixedRecord type="Beam Pattern" length="40">
    <FixedRecordField name="Beam Direction" length="12" type="Euler Angles"/>
    <NumericField name="Azimuth Beamwidth" type="float32" units="radians"/>
    <NumericField name="Elevation Beamwidth" type="float32" units="radians"/>
    <EnumField name="Reference System" type="enum8" enumTableUID="168"/>
    <NumericField name="Padding" type="uint8"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Ez" type="float32"/>
    <NumericField name="Ex" type="float32"/>
    <NumericField name="Phase" type="float32" units="radians"/>
    <NumericField name="Padding" type="uint32"/>
  </FixedRecord>

  <BitRecord type="Beam Status" size="8">
    <BooleanBitField name="Deactivated" bitPosition="0"/>
    <EnumBitField name="Beam Stabilization" bitPosition="1" size="3" enumTableUID="717"/>
    <IntBitField name="Padding" bitPosition="4" size="4"/>
  </BitRecord>

  <FixedRecord type="Entity Coordinate Vector" length="12">
    <NumericField name="Relative Location x-coordinate" type="float32" units="meters"/>
    <NumericField name="Relative Location y-coordinate" type="float32" units="meters"/>
    <NumericField name="Relative Location z-coordinate" type="float32" units="meters"/>
  </FixedRecord>

  <FixedRecord type="Entity Identifier" length="6">
    <FixedRecordField name="Simulation Address" length="4" type="Simulation Address"/>
    <NumericField name="Entity Number" type="uint16"/>
  </FixedRecord>

  <FixedRecord type="Entity Type" length="8">
    <EnumField name="Entity Kind" type="enum8" enumTableUID="7"/>
    <EnumField name="Domain" type="enum8" hierarchyDependency="Entity Kind"/>
    <EnumField name="Country" type="enum16" enumTableUID="29"/>
    <EnumField name="Category" type="enum8" hierarchyDependency="Entity Kind, Domain, Country"/>
    <EnumField name="Subcategory" type="enum8" hierarchyDependency="Category"/>
    <EnumField name="Specific" type="enum8" hierarchyDependency="Subcategory"/>
    <EnumField name="Extra" type="enum8" hierarchyDependency="Entity Kind, Domain, Country, Category, Subcategory, Specific"/>
  </FixedRecord>

  <FixedRecord type="Euler Angles" length="12">
    <NumericField name="Psi" type="float32" units="radians"/>
    <NumericField name="Theta" type="float32" units="radians"/>
    <NumericField name="Phi" type="float32" units="radians"/>
  </FixedRecord>

  <FixedRecord type="Event Identifier" length="6">
    <FixedRecordField name="Simulation Address" length="4" type="Simulation Address"/>
    <NumericField name="Event Number" type="uint16"/>
  </FixedRecord>

  <FixedRecord type="Linear Acceleration Vector" length="12">
    <NumericField name="Acceleration x-coordinate" type="float32" units="meters/sec/sec"/>
    <NumericField name="Acceleration y-coordinate" type="float32" units="meters/sec/sec"/>
    <NumericField name="Acceleration z-coordinate" type="float32" units="meters/sec/sec"/>
  </FixedRecord>

  <FixedRecord type="Linear Velocity Vector" length="12">
    <NumericField name="Velocity x-coordinate" type="float32" units="meters/sec"/>
    <NumericField name="Velocity y-coordinate" type="float32" units="meters/sec"/>
    <NumericField name="Velocity z-coordinate" type="float32" units="meters/sec"/>
  </FixedRecord>

  <FixedRecord type="Named Location Identification" length="4">
    <EnumField name="Station Name" type="enum16" enumTableUID="212"/>
    <NumericField name="Station Number" type="uint16"/>
  </FixedRecord>

  <FixedRecord type="PDU Header" length="16">
    <EnumField name="Protocol Version" type="enum8" enumTableUID="3"/>
    <EnumField name="Compatibility Version" type="enum8" enumTableUID="3"/>
    <NumericField name="Exercise Identifier" type="uint8"/>
    <EnumField name="PDU Type" type="enum8" enumTableUID="4"/>
    <BitRecordField name="PDU Status" size="8" type="PDU Status"/>
    <NumericField name="PDU Header Length" type="uint8"/>
    <NumericField name="PDU Length" type="uint16"/>
    <NumericField name="Timestamp" type="int64" units="microseconds"/>
  </FixedRecord>

  <BitRecord type="PDU Status" size="8">
    <BooleanBitField name="Timestamp Synchronized" bitPosition="0"/>
    <EnumBitField name="LVC" bitPosition="1" size="2" enumTableUID="302"/>
    <EnumBitField name="Transferred Entity Indicator" bitPosition="3" enumTableUID="301"/>
    <IntBitField name="Padding" bitPosition="4" size="4"/>
  </BitRecord>

  <FixedRecord type="Simulation Address" length="4">
    <NumericField name="Site Number" type="uint16"/>
    <NumericField name="Application Number" type="uint16"/>
  </FixedRecord>

  <FixedRecord type="World Coordinates" length="24">
    <NumericField name="X-coordinate" type="float64" units="meters"/>
    <NumericField name="Y-coordinate" type="float64" units="meters"/>
    <NumericField name="Z-coordinate" type="float64" units="meters"/>
  </FixedRecord>

  <ExtensionRecord name="Referenced Entity" recordTypeEnum="2015" baseLength="16" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <FixedRecordField name="Referenced Entity ID" length="6" type="Entity Identifier"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Padding" type="uint32"/>
  </ExtensionRecord>

  <ExtensionRecord name="Relative Entity Location" recordTypeEnum="2016" baseLength="16" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <FixedRecordField name="Relative Location" length="12" type="Entity Coordinate Vector"/>
  </ExtensionRecord>

  <ExtensionRecord name="Relative Entity Location with ID" recordTypeEnum="2017" baseLength="24" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="ID Number" type="uint16"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Padding" type="uint32"/>
    <FixedRecordField name="Relative Location" length="12" type="Entity Coordinate Vector"/>
  </ExtensionRecord>

  <ExtensionRecord name="Source Location" recordTypeEnum="2018" baseLength="32" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="Padding" type="uint32"/>
    <FixedRecordField name="Location" length="24" type="World Coordinates"/>
  </ExtensionRecord>

  <ExtensionRecord name="Source Location/Orientation" recordTypeEnum="2019" baseLength="40" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <FixedRecordField name="Orientation" length="12" type="Euler Angles"/> 
    <FixedRecordField name="Location" length="24" type="World Coordinates"/>
  </ExtensionRecord>

</DISsyntax>
