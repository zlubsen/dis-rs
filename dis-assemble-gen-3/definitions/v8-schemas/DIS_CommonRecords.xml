<?xml version="1.0" encoding="UTF-8"?>

<DISsyntax
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="DISsyntax.xsd"
  title="DIS Syntax Common Records"
  release="0.3"
  date="2025-12-29"
  description="Records used by multiple PDUs and extension records. Conforms to 1278.1-202X Draft 5 and SISO-REF-030 Version 1.0."
  organization="Simulation Interoperability Standards Organization">

