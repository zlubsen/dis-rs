  </ExtensionRecord>

   <FixedRecord type="Sector" length="24">
    <NumericField name="Beam Number" type="uint8"/>
    <BitRecordField name="Flags" size="8" type="Blanking Sectors Flags"/>
    <NumericField name="Blanking Sector ID" type="uint8"/>
    <NumericField name="Padding" type="uint8"/>
    <NumericField name="Left Azimuth" type="float32" units="radians"/>
    <NumericField name="Right Azimuth" type="float32" units="radians"/>
    <NumericField name="Lower Elevation" type="float32" units="radians"/>
    <NumericField name="Upper Elevation" type="float32" units="radians"/>
    <NumericField name="Residual Power" type="float32" units="dBm"/>
  </FixedRecord>

  <BitRecord type="Blanking Sectors Flags" size="8">
    <BooleanBitField name="Deactivated" bitPosition="0"/>
    <IntBitField name="Padding" bitPosition="1" size="7"/>
  </BitRecord>

