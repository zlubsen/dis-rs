  </BitRecord>

  <ExtensionRecord name="False Targets Parameters" recordTypeEnum="3518" baseLength="8" isVariable="true">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Padding" type="uint8"/>
    <Array>
      <CountField name="Number of Parameter Sets" type="uint8"/>
      <FixedRecordField name="False Targets Parameter Set" length="28" type="False Target Parameter Set"/>
