  <PDU name="Acoustic" PDUType="29" protocolFamily="6" baseLength="32">
    <FixedRecordField name="PDU Header" length="16" type="PDU Header"/>
    <FixedRecordField name="Emitting Entity ID" length="6" type="Entity Identifier"/>
    <NumericField name="Passive Parameter Index" type="uint16"/>
    <NumericField name="Padding" type="uint32"/>
    <BitRecordField name="Attributes" size="8" type="Acoustic Attributes"/>
    <BitRecordField name="Propulsion Plant Configuration" size="8" enumTableUID="149"/>
    <ExtensionRecordSet>
      <CountField name="Number Of Extension Records" type="uint16"/>
      <ExtensionRecordFields/>
    </ExtensionRecordSet>
  </PDU>

  <BitRecord type="Acoustic Attributes" size="8">
    <BooleanBitField name="Permanently Associated" bitPosition="0"/>
    <BooleanBitField name="Location Provided" bitPosition="1"/>
    <EnumBitField name="Origin of the Acoustic Emitter" bitPosition="2" size="2" enumTableUID="899"/>
    <IntBitField name="Padding" bitPosition="4" size="4"/>
  </BitRecord>

  <ExtensionRecord name="UA Shaft" recordTypeEnum="7000" baseLength="8" isVariable="true">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Padding" type="uint8"/>
    <Array>
      <CountField name="Number of Shafts" type="uint8"/>
      <FixedRecordField name="Shaft" length="8" type="Shaft"/>
    </Array>
  </ExtensionRecord>

  <FixedRecord type="Shaft" length="8">
    <NumericField name="Current Shaft RPM" type="int16" units="RPM"/>
    <NumericField name="Ordered Shaft RPM" type="int16" units="RPM"/>
    <NumericField name="Shaft RPM Rate of Change" type="int32" units="RPM/sec"/>
  </FixedRecord>

  <ExtensionRecord name="UA APA" recordTypeEnum="7001" baseLength="8" isVariable="true">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Padding" type="uint8"/>
    <Array>
      <CountField name="Number of APAs" type="uint8"/>
      <FixedRecordField name="APA" length="4" type="APA"/>
    </Array>
    <PaddingTo64/>
  </ExtensionRecord>

  <FixedRecord type="APA" length="4">
    <BitRecordField name="APA Parameter Index" size="16" type="APA Parameter Index"/>
    <NumericField name="APA Value" type="int16"/>
  </FixedRecord>

  <BitRecord type="APA Parameter Index" size="16">
    <EnumBitField name="APA Parameter" bitPosition="0" size="14" enumTableUID="150"/>
    <EnumBitField name="APA Status" bitPosition="14" size="2" enumTableUID="281"/>
  </BitRecord>

  <ExtensionRecord name="UA System" recordTypeEnum="7002" baseLength="24" isVariable="true">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="Acoustic System Number" type="uint8"/>
    <EnumField name="Emitter Status" type="enum8" enumTableUID="716"/>
    <NumericField name="Padding" type="uint16"/>
    <FixedRecordField name="Location with Respect to Entity" length="12" type="Entity Coordinate Vector"/>
    <EnumField name="Acoustic System Name" type="enum16" enumTableUID="144"/>
    <EnumField name="Function" type="enum8" enumTableUID="145"/>
    <Array>
      <CountField name="Number of Beams" type="uint8"/>
      <FixedRecordField name="UA Beam Parameter" length="24" type="UA Beam Parameter"/>
    </Array>
  </ExtensionRecord>

  <FixedRecord type="UA Beam Parameter" length="24">
    <NumericField name="Beam ID" type="uint8"/>
    <NumericField name="Padding" type="uint8"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Active Emission Parameter Index" type="uint16"/>
    <EnumField name="Scan Pattern" type="enum16" enumTableUID="147"/>
    <NumericField name="Beam Center Azimuth" type="float32" units="radians"/>
    <NumericField name="Azimuthal Beamwidth" type="float32" units="radians"/>
    <NumericField name="Beam Center D/E" type="float32" units="radians"/>
    <NumericField name="D/E Beamwidth" type="float32" units="radians"/>
  </FixedRecord>

</DISsyntax>
