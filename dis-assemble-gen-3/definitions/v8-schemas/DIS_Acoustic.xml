  title="DIS Syntax Acoustic PDU"
  release="0.3"
  date="2025-12-29"
  description="Acoustic PDU and associated records. Conforms to 1278.1-202X Draft 5 and SISO-REF-030 Version 1.0."
  organization="Simulation Interoperability Standards Organization">

