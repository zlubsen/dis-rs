  <PDU name="Information Operations Action" PDUType="70" protocolFamily="13" baseLength="56">
    <FixedRecordField name="PDU Header" length="16" type="PDU Header"/>
    <FixedRecordField name="IO Attacker Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="IO Primary Target Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="Originating Simulation ID" length="4" type="Simulation Address"/>
    <FixedRecordField name="Receiving Simulation ID" length="4" type="Simulation Address"/>
    <NumericField name="Request ID" type="uint32"/>
    <EnumField name="IO Warfare Type" type="enum16" enumTableUID="285"/>
    <EnumField name="IO Simulation Source" type="enum16" enumTableUID="286"/>
    <EnumField name="IO Action Type" type="enum16" enumTableUID="287"/>
    <EnumField name="IO Action Phase" type="enum16" enumTableUID="288"/>
    <NumericField name="Padding" type="uint32"/>
    <NumericField name="Padding" type="uint16"/>
    <ExtensionRecordSet>
      <CountField name="Number Of Extension Records" type="uint16"/>
      <ExtensionRecordFields/>
    </ExtensionRecordSet>
  </PDU>

  <PDU name="Information Operations Report" PDUType="71" protocolFamily="13" baseLength="40">
    <FixedRecordField name="PDU Header" length="16" type="PDU Header"/>
    <FixedRecordField name="IO Attacker Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="IO Primary Target Entity ID" length="6" type="Entity Identifier"/>
    <EnumField name="IO Simulation Source" type="enum16" enumTableUID="286"/>
    <EnumField name="IO Report Type" type="enum8" enumTableUID="289"/>
    <NumericField name="Padding" type="uint8"/>
    <NumericField name="Padding" type="uint32"/>
    <NumericField name="Padding" type="uint16"/>
    <ExtensionRecordSet>
      <CountField name="Number Of Extension Records" type="uint16"/>
      <ExtensionRecordFields/>
    </ExtensionRecordSet>
  </PDU>

  <ExtensionRecord name="IO Effect" recordTypeEnum="5500" baseLength="16" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <EnumField name="IO Status" type="enum8" enumTableUID="290"/>
    <EnumField name="IO Link Type" type="enum8" enumTableUID="291"/>
    <EnumField name="IO Effect" type="enum8" enumTableUID="292"/>
    <NumericField name="IO Effect Duty Cycle" type="uint8" units="percent"/>
    <NumericField name="IO Effect Duration" type="uint16" units="seconds"/>
    <EnumField name="IO Process" type="enum16" enumTableUID="293"/>
    <NumericField name="Padding" type="uint32"/>
  </ExtensionRecord>

  <ExtensionRecord name="IO Communications Node" recordTypeEnum="5501" baseLength="16" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <EnumField name="Communication Node Type" type="enum8" enumTableUID="294"/>
    <NumericField name="Padding" type="uint8"/>
    <NumericField name="Padding" type="uint16"/>
    <FixedRecordField name="Communication Node ID" length="8" type="Communication Node ID"/>
  </ExtensionRecord>

  <FixedRecord type="Communication Node ID" length="8">
    <FixedRecordField name="Entity ID" length="6" type="Entity Identifier"/>
    <NumericField name="Element ID" type="uint16"/>
  </FixedRecord>

  <ExtensionRecord name="IO Computed Effects" recordTypeEnum="5503" baseLength="24" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <EnumField name="IO Status" type="enum8" enumTableUID="290"/>
    <EnumField name="IO Link Type" type="enum8" enumTableUID="291"/>
    <EnumField name="IO Effect" type="enum8" enumTableUID="292"/>
    <NumericField name="IO Duty Cycle" type="uint8" units="percent"/>
    <NumericField name="IO Effect Duration" type="uint16" units="seconds"/>
    <EnumField name="IO Process" type="enum16" enumTableUID="293"/>
    <FixedRecordField name="Logical Object ID" length="6" type="Entity Identifier"/>
    <NumericField name="Logical Network Number" type="uint16"/>
    <NumericField name="Logical Channel Number" type="uint16"/>
    <NumericField name="Physical Network Number" type="uint16"/>
  </ExtensionRecord>

</DISsyntax>
