  <PDU name="Fire" PDUType="2" protocolFamily="2" baseLength="96">
    <FixedRecordField name="PDU Header" length="16" type="PDU Header"/>
    <FixedRecordField name="Firing Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="Target Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="Munition/Expendable Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="Fire Event ID" length="6" type="Event Identifier"/>
    <FixedRecordField name="Location in World Coordinates" length="24" type="World Coordinates"/>
    <FixedRecordField name="Velocity" length="12" type="Linear Velocity Vector"/>
    <NumericField name="Fire Mission Index" type="uint32"/>
    <FixedRecordField name="Munition/Expendable Type" length="8" type="Entity Type"/>
    <NumericField name="Range" type="float32"  units="meters"/>
    <EnumField name="Fire Type Indicator" type="enum8" enumTableUID="304"/>
    <NumericField name="Padding" type="uint8"/>
    <ExtensionRecordSet>
      <CountField name="Number of Extension Records" type="uint16"/>
      <ExtensionRecordFields/>
    </ExtensionRecordSet>
  </PDU>

  <PDU name="Detonation" PDUType="3" protocolFamily="2" baseLength="104">
    <FixedRecordField name="PDU Header" length="16" type="PDU Header"/>
    <FixedRecordField name="Source Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="Target Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="Exploding Entity ID" length="6" type="Entity Identifier"/>
    <FixedRecordField name="Fire Event ID" length="6" type="Event Identifier"/>
    <FixedRecordField name="Location in World Coordinates" length="24" type="World Coordinates"/>
    <FixedRecordField name="Velocity" length="12" type="Linear Velocity Vector"/>
    <FixedRecordField name="Location In Entity Coordinates" length="12" type="Entity Coordinate Vector"/>
    <FixedRecordField name="Munition/Expendable/Explosion Type" length="8" type="Entity Type"/>
    <NumericField name="Padding" type="uint32"/>
    <EnumField name="Detonation Type Indicator" type="enum8" enumTableUID="305"/>
    <EnumField name="Detonation Result" type="enum8" enumTableUID="62"/>
    <ExtensionRecordSet>
      <CountField name="Number of Extension Records" type="uint16"/>
      <ExtensionRecordFields/>
    </ExtensionRecordSet>
  </PDU>

  <PDU name="Directed Energy Fire" PDUType="68" protocolFamily="2" baseLength="88">
    <FixedRecordField name="PDU Header" length="16" type="PDU Header"/>
    <FixedRecordField name="Firing Entity ID" length="6" type="Entity Identifier"/>
    <NumericField name="Padding" type="uint16"/>
    <FixedRecordField name="Fire Event ID" length="6" type="Event Identifier"/>
    <BitRecordField name="Flags" size="16" enumTableUID="313"/>
    <FixedRecordField name="Munition Type" length="8" type="Entity Type"/>
    <NumericField name="Shot Start Time" type="int64" units="microseconds"/>
    <NumericField name="Cumulative Shot Time" type="float32" units="seconds"/>
    <FixedRecordField name="Aperture/Emitter Location In Firing Entity Coordinates" length="12" type="Entity Coordinate Vector"/>
    <NumericField name="Aperture Diameter" type="float32" units="meters"/>
    <NumericField name="Wavelength" type="float32" units="meters"/>
    <NumericField name="Padding" type="uint32"/>
    <NumericField name="Pulse Repetition Frequency" type="float32" units="Hertz"/>
    <NumericField name="Pulse Width" type="float32" units="seconds"/>
    <EnumField name="Pulse Shape" type="enum8" enumTableUID="312"/>
    <NumericField name="Padding" type="uint8"/>
    <ExtensionRecordSet>
      <CountField name="Number of Extension Records" type="uint16"/>
      <ExtensionRecordFields/>
    </ExtensionRecordSet>
  </PDU>

  <PDU name="Entity Damage Status" PDUType="69" protocolFamily="2" baseLength="24">
    <FixedRecordField name="PDU Header" length="16" type="PDU Header"/>
    <FixedRecordField name="Damaged Entity ID" length="6" type="Entity Identifier"/>
    <ExtensionRecordSet>
      <CountField name="Number of Extension Records" type="uint16"/>
      <ExtensionRecordFields/>
    </ExtensionRecordSet>
  </PDU>

  <ExtensionRecord name="DE Precision Aimpoint" recordTypeEnum="4000" baseLength="88" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <FixedRecordField name="Target Spot Entity Location" length="12" type="Entity Coordinate Vector"/>
    <FixedRecordField name="Target Spot World Location" length="24" type="World Coordinates"/>
    <FixedRecordField name="Target Spot Velocity" length="12" type="Linear Velocity Vector"/>
    <FixedRecordField name="Target Spot Acceleration" length="12" type="Linear Acceleration Vector"/>
    <FixedRecordField name="Target Entity ID" length="6" type="Entity Identifier"/>
    <EnumField name="Target Component Identifier" type="enum8" enumTableUID="314"/>
    <EnumField name="Beam Spot Type" type="enum8" enumTableUID="311"/>
    <NumericField name="Beam Spot Cross-Section Semi-Major Axis" type="float32" units="meters"/>
    <NumericField name="Beam Spot Cross-Section Semi-Minor Axis" type="float32" units="meters"/>
    <NumericField name="Beam Spot Cross-Section Orientation Angle" type="float32" units="radians"/>
    <NumericField name="Peak Irradiance" type="float32" units="Watts per sqare meter"/>
  </ExtensionRecord>

  <ExtensionRecord name="DE Area Aimpoint" recordTypeEnum="4001" baseLength="12" isVariable="true">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="Padding" type="uint16"/>
    <Array>
      <CountField name="Number of Beam Patterns" type="uint16"/>
      <FixedRecordField name="Beam Pattern" length="40" type="Beam Pattern"/>
    </Array>
    <NumericField name="Padding" type="uint16"/>
    <Array>
      <CountField name="Number of DE Target Energy Depositions" type="uint16"/>
      <FixedRecordField name="DE Target Energy Deposition" length="12" type="DE Target Energy Deposition"/>
    </Array>
    <PaddingTo64/>
  </ExtensionRecord>

  <FixedRecord type="DE Target Energy Deposition" length="12">
    <FixedRecordField name="Target Entity ID" length="6" type="Entity Identifier"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Peak Irradiance" type="float32" units="Watts per square meter"/>
  </FixedRecord>

  <ExtensionRecord name="Munition Descriptor" recordTypeEnum="4200" baseLength="16" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="Padding" type="uint32"/>
    <EnumField name="Warhead" type="enum16" enumTableUID="60"/>
    <EnumField name="Fuse" type="enum16" enumTableUID="61"/>
    <NumericField name="Quantity" type="uint16"/>
    <NumericField name="Rate" type="uint16" units="rounds per minute"/>
  </ExtensionRecord>

  <ExtensionRecord name="Explosion Descriptor" recordTypeEnum="4201" baseLength="16" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <EnumField name="Explosive Material" type="enum16" enumTableUID="310"/>
    <NumericField name="Padding" type="uint16"/>
    <NumericField name="Explosive Force" type="float32" units="kg TNT"/>
    <NumericField name="Padding" type="uint32"/>
  </ExtensionRecord>

  <ExtensionRecord name="Directed Energy Damage Description" recordTypeEnum="4500" baseLength="40" isVariable="false">
    <EnumField name="Record Type" type="enum16" enumTableUID="99"/>
    <NumericField name="Record Length" type="uint16"/>
    <NumericField name="Padding" type="uint32"/>
    <FixedRecordField name="Damage Location" length="12" type="Entity Coordinate Vector"/>
    <NumericField name="Damage Diameter" type="float32" units="meters"/>
    <NumericField name="Temperature" type="float32" units="degrees Celsius"/>
    <EnumField name="Component Identification" type="enum8" enumTableUID="314"/>
    <EnumField name="Component Damage Status" type="enum8" enumTableUID="315"/>
    <BitRecordField name="Component Visual Damage Status" size="8" enumTableUID="317"/>
    <EnumField name="Component Visual Smoke Color" type="enum8" enumTableUID="316"/>
    <FixedRecordField name="Fire Event ID" length="6" type="Event Identifier"/>
    <NumericField name="Padding" type="uint16"/>
  </ExtensionRecord>

</DISsyntax>
